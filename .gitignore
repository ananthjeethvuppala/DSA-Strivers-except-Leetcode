```gitignore
# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual Environment
venv/
.venv/
env/

# VS Code
.vscode/

# PyCharm
.idea/

# OS Files
.DS_Store
Thumbs.db

# Python environment
.python-version

# Logs
*.log

# Jupyter Notebook
.ipynb_checkpoints/

# Hugging Face cache
.cache/
.huggingface/

# Environment variables
.env

# Build files
build/
dist/
*.egg-info/

# Temporary files
*.tmp
```
